# Copy this file to .env and fill in your own ElevenLabs key.
# .env is gitignored and must never be committed. Only the API key is secret —
# the voice / model / seed below reproduce this demo's narration exactly.
# (Voice settings — stability, style, etc. — live in audio/generate.py.)
ELEVENLABS_API_KEY=your-key-here
ELEVENLABS_VOICE_ID=iP95p4xoKVk53GoZ742B   # "Chris - Down to Earth" (ElevenLabs voice library)
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_SEED=12345
